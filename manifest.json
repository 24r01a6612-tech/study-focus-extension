{
  "manifest_version": 3,
  "name": "Study Focus",
  "version": "1.0",
  "permissions": [
    "storage",
    "tabs",
    "notifications",
     "offscreen"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
  "service_worker": "background.js"
},
  "action": {
    "default_popup": "popup.html"
  }
}